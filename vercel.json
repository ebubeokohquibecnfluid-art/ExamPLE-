{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*",           "destination": "https://exam-ple--bubeelyon.replit.app/api/:path*" },
    { "source": "/admin/stats",                       "destination": "https://exam-ple--bubeelyon.replit.app/admin/stats" },
    { "source": "/admin/users",                       "destination": "https://exam-ple--bubeelyon.replit.app/admin/users" },
    { "source": "/admin/users/:uid",                  "destination": "https://exam-ple--bubeelyon.replit.app/admin/users/:uid" },
    { "source": "/admin/schools",                     "destination": "https://exam-ple--bubeelyon.replit.app/admin/schools" },
    { "source": "/admin/schools/:id/students",        "destination": "https://exam-ple--bubeelyon.replit.app/admin/schools/:id/students" },
    { "source": "/admin/schools/:id",                 "destination": "https://exam-ple--bubeelyon.replit.app/admin/schools/:id" },
    { "source": "/admin/withdrawals/mark-paid",       "destination": "https://exam-ple--bubeelyon.replit.app/admin/withdrawals/mark-paid" },
    { "source": "/admin/withdrawals",                 "destination": "https://exam-ple--bubeelyon.replit.app/admin/withdrawals" },
    { "source": "/admin/topup",                       "destination": "https://exam-ple--bubeelyon.replit.app/admin/topup" },
    { "source": "/admin/activity",                    "destination": "https://exam-ple--bubeelyon.replit.app/admin/activity" },
    { "source": "/ask-question",         "destination": "https://exam-ple--bubeelyon.replit.app/ask-question" },
    { "source": "/get-audio",            "destination": "https://exam-ple--bubeelyon.replit.app/get-audio" },
    { "source": "/school-dashboard",     "destination": "https://exam-ple--bubeelyon.replit.app/school-dashboard" },
    { "source": "/school-login",         "destination": "https://exam-ple--bubeelyon.replit.app/school-login" },
    { "source": "/register-school",      "destination": "https://exam-ple--bubeelyon.replit.app/register-school" },
    { "source": "/request-withdrawal",   "destination": "https://exam-ple--bubeelyon.replit.app/request-withdrawal" },
    { "source": "/(.*)",                 "destination": "/index.html" }
  ]
}
